            this.winnerPlayerA = doublesBPlayerA;
            this.winnerPlayerB = doublesBPlayerB;
            this.loserDoubles = doublesA;
            this.loserPlayerA = doublesAPlayerA;
            this.loserPlayerB = doublesAPlayerB;
        }
    }

